@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.States
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject UserState UserState
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthenticationService AuthService
@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col bg-gray-50">

    <!-- TOP BAR -->
    <div class="bg-primary text-sm text-white">
        <div class="mx-auto flex max-w-7xl justify-between px-6 py-2">
            <span class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.46-5.322-3.886-6.782-6.782l1.292-.971c.361-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                Llámanos: (301) 123-4567
            </span> 
            <a href="https://wa.me/573128883241" target="_blank" class="flex items-center gap-2 text-white opacity-90 hover:opacity-100 hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c-.003 1.396.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c.003-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
                </svg>
                WhatsApp: Escríbenos ahora
            </a>
        </div>
    </div>

    <!-- HEADER -->
    <header class="sticky top-0 z-50 border-b border-slate-100 bg-white shadow-sm shadow-slate-200/50">
        <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-0 h-[60px]">

            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 text-lg font-bold text-primary tracking-tight shrink-0">
                Piedra Azul
            </a>

            <!-- Desktop nav -->
            <nav class="hidden md:flex items-center gap-1 text-sm text-gray-600">
                <a href="/" class="flex items-center gap-1.5 px-3 py-2 rounded-lg transition-colors hover:bg-gray-100 hover:text-gray-900 font-medium">
                    Inicio
                </a>
                @if (UserState?.User?.Roles.Contains("Admin") == true)
                {
                    <a href="/admin" class="px-3 py-2 rounded-lg transition-colors hover:bg-gray-100 hover:text-gray-900 font-medium">Admin</a>
                    <a href="/admin/configurar-horario" class="px-3 py-2 rounded-lg transition-colors hover:bg-gray-100 hover:text-gray-900 font-medium">Horario</a>
                }
                @if (UserState?.User?.Roles.Contains("Doctor") == true)
                {
                    <a href="/doctor" class="flex items-center gap-1.5 px-3 py-2 rounded-lg transition-colors hover:bg-gray-100 font-semibold text-primary">
                        Médico
                    </a>
                }
                <a class="flex items-center gap-1.5 px-3 py-2 rounded-lg transition-colors hover:bg-gray-100 hover:text-gray-900 font-medium cursor-pointer">
                    Ayuda
                </a>

                @if (!_isLoaded)
                {
                    <span class="ml-2 flex items-center gap-2 bg-primary rounded-lg px-4 py-2 text-white text-sm font-semibold opacity-80 cursor-default select-none">
                        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        Cargando...
                    </span>
                }
                else if (_isAuthenticated)
                {
                    <a href="/account" class="ml-2 flex items-center gap-2 bg-primary rounded-lg px-4 py-2 text-white text-sm font-semibold hover:bg-[#1a5b67] transition-colors">
                        ¡Bienvenido, @(_userName?.Split(' ')[0])!
                    </a>
                }
                else
                {
                    <a href="/account/auth" class="ml-2 bg-primary rounded-md px-6 py-2 text-white text-sm font-bold hover:opacity-90 transition-all shadow-md shadow-primary/25 active:scale-95">
                        Iniciar Sesión
                    </a>
                }
            </nav>

            <!-- Hamburger (mobile only) -->
            <button @onclick="ToggleMobileMenu"
                    class="md:hidden flex items-center justify-center p-2 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors"
                    aria-label="Abrir menú">
                <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>

        </div>
    </header>

    <!-- MOBILE OVERLAY -->
    @if (_mobileMenuOpen)
    {
        <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] md:hidden"
             @onclick="CloseMobileMenu"></div>
    }

    <!-- MOBILE DRAWER -->
    <div class="fixed top-0 right-0 bottom-0 w-[270px] bg-white shadow-2xl z-[61] flex flex-col transition-transform duration-300 md:hidden
        @(_mobileMenuOpen ? "translate-x-0" : "translate-x-full")">

        <!-- Drawer header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-50">
            <a href="/" class="flex items-center gap-2 text-base font-bold text-primary tracking-tight" @onclick="CloseMobileMenu">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2C8.5 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3.5-7-7-7z" fill="#2A9D8F" opacity="0.85" />
                    <circle cx="12" cy="9" r="3" fill="white" opacity="0.9" />
                </svg>
                Piedra Azul
            </a>
            <button @onclick="CloseMobileMenu"
                    class="p-1.5 rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-700 transition-colors">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>

        <!-- Drawer user info (authenticated only) -->
        @if (_isAuthenticated)
        {
            <div class="flex items-center gap-3 px-5 py-4 border-b border-slate-50">
                <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center text-sm font-bold text-primary shrink-0">
                    @(_userName?.Split(' ') is { Length: >= 2 } parts ? $"{parts[0][0]}{parts[1][0]}" : _userName?[..1] ?? "U")
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 truncate">@_userName</p>
                    <span class="inline-block mt-0.5 text-[11px] font-semibold bg-teal-50 text-primary px-2 py-0.5 rounded-full">
                        Paciente
                    </span>
                </div>
            </div>
        }

        <!-- Drawer links -->
        <div class="flex-1 overflow-y-auto px-3 py-3 flex flex-col gap-0.5">
            <a href="/" @onclick="CloseMobileMenu"
                   class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-medium text-gray-700 rounded-lg hover:bg-gray-100 hover:text-gray-900 transition-colors">
                Inicio
            </a>
            @if (UserState?.User?.Roles.Contains("Admin") == true)
            {
                <a href="/admin" @onclick="CloseMobileMenu"
                       class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-medium text-gray-700 rounded-lg hover:bg-gray-100 hover:text-gray-900 transition-colors">
                    Admin
                </a>
            }
            @if (UserState?.User?.Roles.Contains("Doctor") == true)
            {
                <a href="/doctor" @onclick="CloseMobileMenu"
                       class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-semibold text-primary rounded-lg hover:bg-teal-50 transition-colors">
                    Médico
                </a>
            }
            <a class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-medium text-gray-700 rounded-lg hover:bg-gray-100 hover:text-gray-900 transition-colors cursor-pointer">
                Ayuda
            </a>

            @if (_isAuthenticated)
            {
                <hr class="my-2 border-gray-200" />
                <a href="/account" @onclick="CloseMobileMenu"
                       class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-medium text-gray-700 rounded-lg hover:bg-gray-100 hover:text-gray-900 transition-colors">
                    Mi cuenta
                </a>
                <button class="flex items-center gap-3 w-full px-3 py-3 text-[15px] font-medium text-red-500 rounded-lg hover:bg-red-50 transition-colors text-left">
                    Cerrar sesión
                </button>
            }
        </div>

        <!-- Drawer CTA (guest only) -->
        @if (!_isAuthenticated && _isLoaded)
        {
            <div class="p-4 border-t border-slate-50">
                <a href="/account/auth" @onclick="CloseMobileMenu"
                       class="block w-full text-center py-3 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-[#1a5b67] transition-colors">
                    Iniciar sesión
                </a>
            </div>
        }
    </div>

    <!-- MAIN -->
    <main class="flex flex-1 flex-col">
        @Body
    </main>

    <!-- FOOTER -->
    <footer class="bg-strong text-gray-300">
        <div class="mx-auto grid max-w-7xl gap-10 px-6 py-12 md:grid-cols-3">

            <div>
                <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-white">
                    Piedra Azul
                </h3>
                <p class="text-sm text-gray-400 leading-relaxed">
                    Dedicados a mejorar la calidad de vida de nuestra comunidad
                    con atención profesional y humana.
                </p>
            </div>

            <div>
                <h4 class="mb-4 font-semibold text-white">Enlaces</h4>
                <ul class="space-y-2 text-sm">
                    <li><a class="text-gray-400 hover:text-white transition-colors cursor-pointer">Acerca de nosotros</a></li>
                    <li><a class="text-gray-400 hover:text-white transition-colors cursor-pointer">Servicios médicos</a></li>
                    <li><a class="text-gray-400 hover:text-white transition-colors cursor-pointer">Preguntas frecuentes</a></li>
                    <li><a class="text-gray-400 hover:text-white transition-colors cursor-pointer">Política de privacidad</a></li>
                </ul>
            </div>

            <div>
                <h4 class="mb-4 font-semibold text-white">Contacto Directo</h4>
                <div class="space-y-3">
                    <button class="w-full rounded-lg bg-primary py-2.5 text-sm font-bold text-white hover:opacity-90 transition-all shadow-sm shadow-primary/20 active:scale-95">
                        (+57) 301-1234567
                    </button>
                    <a href="https://wa.me/573128883241" target="_blank" class="w-full rounded-lg bg-green-600 py-2.5 text-sm font-bold text-white hover:opacity-90 transition-all shadow-sm shadow-green-500/20 active:scale-95 flex items-center justify-center gap-2">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                        </svg>
                        WhatsApp
                    </a>
                </div>
            </div>

        </div>

        <div class="border-t border-slate-800/60 py-4 text-center text-sm text-gray-500">
            © 2026 Clínica Piedra Azul. Todos los derechos reservados.
        </div>
    </footer>

</div>

<!-- ERROR UI -->
<div id="blazor-error-ui"
     data-nosnippet
     class="-translate-x-1/2 fixed bottom-4 left-1/2 w-[90%] max-w-lg rounded-2xl border border-red-100 bg-white p-6 shadow-2xl hidden">
    <div class="flex items-start gap-4">
        <svg class="shrink-0 mt-0.5 text-red-400 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <circle cx="12" cy="16" r=".5" fill="currentColor" />
        </svg>
        <div class="flex-1">
            <h2 class="mb-1 text-base font-semibold text-gray-800">
                Algo no salió como esperábamos
            </h2>
            <p class="mb-4 text-sm text-gray-500 leading-relaxed">
                No se preocupe, esto a veces ocurre.
                Puede intentar recargar la página para continuar.
            </p>
            <div class="flex gap-3">
                <a href="." class="reload rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-800 transition-colors">
                    Recargar página
                </a>
                <a class="dismiss rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 transition-colors cursor-pointer">
                    Descartar
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isLoaded = false;
    private bool _isAuthenticated = false;
    private string? _userName;
    private bool _mobileMenuOpen = false;

    private void ToggleMobileMenu() => _mobileMenuOpen = !_mobileMenuOpen;
    private void CloseMobileMenu() => _mobileMenuOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated == true)
        {
            _isAuthenticated = true;

            var userResult = await AuthService.GetCurrentUserAsync();
            if (userResult.IsSuccess && userResult.Value is not null)
            {
                UserState.User = userResult.Value;
            }

            _userName = UserState.User?.Name;
        }

        _isLoaded = true;
    }
}