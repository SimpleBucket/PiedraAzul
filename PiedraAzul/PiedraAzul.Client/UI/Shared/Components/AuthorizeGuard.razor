@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.States
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject UserState UserState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

@if (isChecking)
{
    <p>Cargando...</p>
}
else
{
    @ChildContent
}

@code {
    [Parameter, EditorRequired] public string? RequiredRole { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string ReturnUrl { get; set; } = "/";
    private bool isChecking = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
            NavigationManager.NavigateTo($"/account/auth?returnUrl={returnUrl}");
            return;
        }

        if (UserState.User == null)
        {
            UserState.User = new UserGQL
            {
                Id        = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "",
                Name      = principal.FindFirst("name")?.Value ?? principal.FindFirst(ClaimTypes.Name)?.Value ?? "",
                Email     = principal.FindFirst(ClaimTypes.Email)?.Value ?? "",
                AvatarUrl = principal.FindFirst("avatar_url")?.Value ?? "default.png",
                Roles     = principal.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList(),
                EmailConfirmed = true
            };
        }

        if (!string.IsNullOrEmpty(RequiredRole) && !UserState.User.Roles.Contains(RequiredRole))
        {
            NavigationManager.NavigateTo(ReturnUrl);
            return;
        }

        isChecking = false;
    }
}
