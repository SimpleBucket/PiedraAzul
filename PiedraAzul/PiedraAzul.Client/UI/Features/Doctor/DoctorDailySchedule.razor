@page "/doctor/cronograma-diario"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using System.Globalization
@using PiedraAzul.Client.States
@inject UserState UserState
@inject NavigationManager NavigationManager

<div class="min-h-screen bg-slate-50 pb-12">

    <!-- HEADER / NAV -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="bg-primary p-2 rounded-lg text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </div>
                    <span class="text-xl font-bold text-slate-800">Piedra Azul</span>
                </div>

                <!-- Nav Links -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="/doctor" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Dashboard</a>
                    <a href="/doctor/pacientes" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Pacientes</a>
                    <a href="/doctor/agenda" class="text-slate-900 font-semibold border-b-2 border-primary py-7">Mi Agenda</a>
                </nav>
            </div>

            <div class="flex items-center gap-6">
                <!-- User Profile -->
                <div class="flex items-center gap-3 pl-6 border-l">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-slate-900">Dr. Roberto Gómez</div>
                        <div class="text-xs text-slate-400">Doctor</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Roberto+Gomez&background=257D8D&color=fff" alt="Doctor" class="w-10 h-10 rounded-full border-2 border-slate-100 shadow-sm" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 mt-8">
        <!-- Breadcrumbs -->
        <nav class="flex text-sm text-slate-400 mb-6 font-medium" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2">
                <li><a href="/doctor/agenda" class="hover:text-primary transition-colors">Mi agenda</a></li>
                <li class="flex items-center space-x-2">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                    <a href="/doctor/agenda" class="hover:text-primary transition-colors">Horario</a>
                </li>
                <li class="flex items-center space-x-2">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-slate-600">Cronograma diario</span>
                </li>
            </ol>
        </nav>
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-8">
            
            <!-- Left Column: Schedule Table -->
            <div class="space-y-6">
                <!-- Date Navigation Card -->
                <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900 mb-1">Cronograma diario</h1>
                        <p class="text-slate-400 font-medium capitalize">@SelectedDate.ToString("dddd, dd MMMM, yyyy", new CultureInfo("es-ES"))</p>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <div class="flex items-center bg-slate-50 p-1.5 rounded-2xl border border-slate-100">
                            <button @onclick="PrevDay" class="p-2.5 rounded-xl text-slate-400 hover:bg-white hover:shadow-sm transition-all">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                            </button>
                            <span class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold shadow-lg shadow-primary/20">
                                @GetDateLabel(SelectedDate)
                            </span>
                            <button @onclick="NextDay" class="p-2.5 rounded-xl text-slate-400 hover:bg-white hover:shadow-sm transition-all">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </button>
                        </div>
                        <button class="p-4 bg-white border border-slate-200 rounded-2xl text-primary hover:bg-slate-50 transition-all shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <footer class="mt-20 flex flex-col md:flex-row items-center justify-between gap-6 py-8 border-t border-slate-100">
            <div class="text-slate-400 font-medium italic text-sm">
                © 2026 Clínica Piedra Azul.
            </div>
            <div class="flex items-center gap-8 text-sm font-bold text-slate-500">
                <a href="#" class="hover:text-primary transition-colors">Política de Privacidad</a>
                <a href="#" class="hover:text-primary transition-colors">Términos y condiciones</a>
                <a href="#" class="hover:text-primary transition-colors">Soporte</a>
            </div>
        </footer>
    </main>
</div>

@code {
    [Parameter] [SupplyParameterFromQuery] public string? date { get; set; }
    private DateTime SelectedDate { get; set; } = DateTime.Today;

    protected override void OnInitialized()
    {
        if (DateTime.TryParse(date, out var parsedDate))
        {
            SelectedDate = parsedDate;
        }
    }

    private void PrevDay() => SelectedDate = SelectedDate.AddDays(-1);
    private void NextDay() => SelectedDate = SelectedDate.AddDays(1);

    private string GetDateLabel(DateTime date)
    {
        var diff = (date.Date - DateTime.Today).Days;
        if (diff == 0) return "Hoy";
        if (diff == -1) return "Ayer";
        if (diff == 1) return "Mañana";
        
        if (diff < 0) {
            int days = Math.Abs(diff);
            if (days >= 31) {
                int months = days / 30;
                return $"Hace {months} {(months == 1 ? "mes" : "meses")}";
            }
            return $"Hace {days} días";
        } else {
            if (diff >= 31) {
                int months = diff / 30;
                return $"En {months} {(months == 1 ? "mes" : "meses")}";
            }
            return $"En {diff} días";
        }
    }
}

<style>
    .bg-primary { background-color: #257D8D; }
    .text-primary { color: #257D8D; }
    .border-primary { border-color: #257D8D; }
    .shadow-primary\/20 { --tw-shadow-color: rgba(37, 125, 141, 0.2); }
    .shadow-primary\/40 { --tw-shadow-color: rgba(37, 125, 141, 0.4); }
</style>
