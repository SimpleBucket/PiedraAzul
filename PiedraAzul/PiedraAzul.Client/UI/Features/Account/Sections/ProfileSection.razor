@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.Services.GraphQLServices
@using PiedraAzul.Client.States
@using PiedraAzul.Client.UI.Features.Account.Components
@inject AuthenticationService AuthService
@inject UserState UserState
@inject GraphQLHttpClient GraphQL
@inject HttpClient Http

@if (_user is null)
{
    <div class="flex justify-center py-20"><div class="spinner"></div></div>
}
else
{
    <!-- Mobile user header -->
    <div class="mb-4 flex items-center gap-3 md:hidden">
        <div class="relative flex-shrink-0">
            <img src="@AvatarSrc" alt="Avatar"
                 class="h-10 w-10 rounded-full object-cover border-2 border-[#E2E8F0]" />
            <label class="absolute -bottom-0.5 -right-0.5 cursor-pointer rounded-full bg-[#257D8D] p-1 shadow" title="Cambiar foto">
                <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                    <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                <InputFile OnChange="OnAvatarSelected" accept="image/*" class="hidden" />
            </label>
        </div>
        <div>
            <p class="text-sm font-bold text-[#0F172A]">@_user.Name</p>
            <p class="text-xs text-[#94A3B8]">@_user.Email</p>
        </div>
    </div>

    <div class="mb-5">
        <h2 class="text-[22px] font-extrabold tracking-tight text-[#0F172A]">Mi perfil</h2>
        <p class="mt-0.5 text-[13px] text-[#64748B]">Gestiona tu información personal y datos de contacto.</p>
    </div>

    @if (!string.IsNullOrEmpty(_avatarError))
    {
        <div class="w-full mb-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">@_avatarError</div>
    }
    @if (_avatarSuccess)
    {
        <div class="w-full mb-4 rounded-2xl border border-[#4CAF7D] bg-[#edf7f2] px-4 py-3 text-sm text-[#166534]">Foto actualizada correctamente.</div>
    }

    <!-- Personal info card -->
    <div class="mb-5 rounded-2xl border border-[#E2E8F0] bg-white p-6">
        <p class="mb-4 text-[13px] font-bold text-[#0F172A]">Información personal</p>

        <div class="mb-5 flex items-center gap-4 rounded-xl border border-[#E2E8F0] bg-[#F8FAFC] p-3.5">
            <div class="relative flex-shrink-0">
                <img src="@AvatarSrc" alt="Avatar"
                     class="h-12 w-12 rounded-full object-cover border-2 border-[#E2E8F0]" />
                <label class="absolute -bottom-0.5 -right-0.5 cursor-pointer rounded-full bg-[#257D8D] p-1 shadow hover:bg-[#1a5f6d] transition" title="Cambiar foto">
                    <svg class="h-2.5 w-2.5" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    <InputFile OnChange="OnAvatarSelected" accept="image/*" class="hidden" />
                </label>
            </div>
            <div>
                <p class="text-sm font-bold text-[#0F172A]">@_user.Name</p>
                <p class="text-[12px] text-[#64748B]">@_user.Email</p>
                <div class="mt-1.5 flex flex-wrap gap-1">
                    @foreach (var role in _user.Roles)
                    {
                        <span class="rounded-full bg-blue-50 px-2 py-0.5 text-[11px] font-bold text-blue-600 capitalize">@role</span>
                    }
                </div>
            </div>
        </div>

        <div>
            <label class="mb-1.5 block text-xs font-semibold text-[#374151]">Nombre completo</label>
            <div class="flex gap-2.5">
                <input @bind="_editName" @bind:event="oninput"
                       class="flex-1 rounded-xl border border-[#CBD5E1] bg-white px-3.5 py-2.5 text-[13px] text-[#0F172A]
                              focus:border-[#257D8D] focus:outline-none focus:ring-2 focus:ring-[#257D8D]/20 transition" />
                <button @onclick="SaveNameAsync"
                        disabled="@(_savingName || _editName == _user.Name)"
                        class="rounded-xl bg-[#257D8D] px-5 py-2.5 text-[13px] font-bold text-white
                               transition hover:bg-[#1a5f6d] disabled:opacity-50">
                    @(_savingName ? "Guardando…" : "Guardar")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_nameMsg))
            {
                <p class="mt-1.5 text-xs @(_nameError ? "text-red-500" : "text-[#059669]")">@_nameMsg</p>
            }
        </div>
    </div>

    <!-- Email card -->
    <div class="rounded-2xl border border-[#E2E8F0] bg-white p-6">
        <p class="mb-1 text-[13px] font-bold text-[#0F172A]">Correo electrónico</p>
        <p class="mb-4 text-[12px] text-[#64748B]">Para cambiar tu correo te enviaremos un código de verificación.</p>
        <EmailChange CurrentEmail="@(_user.Email ?? "")" GraphQL="@GraphQL" OnEmailChanged="ReloadUserAsync" />
    </div>

    <!-- Email verification modal -->
    @if (_showEmailVerification)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4">
            <div class="w-full max-w-sm rounded-2xl bg-white p-6 shadow-xl">
                @if (!_emailVerificationStep2)
                {
                    <h3 class="mb-2 text-base font-extrabold text-[#0F172A]">Verificar email</h3>
                    <p class="mb-5 text-[13px] text-[#475569]">
                        Enviaremos un código de verificación a <strong>@_user.Email</strong>
                    </p>
                    <div class="flex gap-2">
                        <button @onclick="SendEmailVerificationCode" disabled="@_emailVerificationLoading"
                                class="flex-1 rounded-xl bg-[#257D8D] px-4 py-2.5 text-sm font-bold text-white
                                       transition hover:bg-[#1a5f6d] disabled:opacity-50">
                            @(_emailVerificationLoading ? "Enviando..." : "Enviar código")
                        </button>
                        <button @onclick="() => _showEmailVerification = false"
                                class="flex-1 rounded-xl border border-[#CBD5E1] px-4 py-2.5 text-sm font-bold
                                       text-[#475569] transition hover:bg-gray-50">
                            Cancelar
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_emailVerificationError))
                    {
                        <p class="mt-3 text-[13px] text-red-500">@_emailVerificationError</p>
                    }
                }
                else
                {
                    <h3 class="mb-2 text-base font-extrabold text-[#0F172A]">Ingresar código</h3>
                    <p class="mb-4 text-[13px] text-[#475569]">Ingresa el código de 6 dígitos que recibiste en tu email</p>
                    <input type="text" @bind="_emailVerificationCode" maxlength="6" placeholder="000000"
                           class="mb-4 w-full rounded-xl border border-[#CBD5E1] px-4 py-2.5 text-center text-2xl
                                  tracking-widest focus:border-[#257D8D] focus:outline-none focus:ring-2 focus:ring-[#257D8D]/20"
                           autocomplete="off" />
                    <div class="flex gap-2 mb-3">
                        <button @onclick="VerifyEmailCode"
                                disabled="@(_emailVerificationCode?.Length != 6 || _emailVerificationLoading)"
                                class="flex-1 rounded-xl bg-[#257D8D] px-4 py-2.5 text-sm font-bold text-white
                                       transition hover:bg-[#1a5f6d] disabled:opacity-50">
                            @(_emailVerificationLoading ? "Verificando..." : "Verificar")
                        </button>
                        <button @onclick="CloseEmailVerification"
                                class="flex-1 rounded-xl border border-[#CBD5E1] px-4 py-2.5 text-sm font-bold
                                       text-[#475569] transition hover:bg-gray-50">
                            Cancelar
                        </button>
                    </div>
                    <button @onclick="() => _emailVerificationStep2 = false"
                            class="w-full text-xs font-semibold text-[#257D8D] hover:underline">
                        ← Cambiar email
                    </button>
                    @if (!string.IsNullOrEmpty(_emailVerificationError))
                    {
                        <p class="mt-3 text-[13px] text-red-500">@_emailVerificationError</p>
                    }
                }
            </div>
        </div>
    }

    <!-- Unverified email banner -->
    @if (!string.IsNullOrEmpty(_user.Email) && !_user.EmailConfirmed)
    {
        <div class="mt-5 flex items-center justify-between rounded-2xl border border-yellow-300 bg-yellow-50 p-4">
            <div class="flex items-center gap-3">
                <span class="text-lg">📧</span>
                <div>
                    <p class="text-sm font-bold text-[#0F172A]">Email no verificado</p>
                    <p class="text-xs text-[#64748B]">Verifica tu email para completar tu cuenta</p>
                </div>
            </div>
            <button @onclick="() => _showEmailVerification = true"
                    class="flex-shrink-0 rounded-lg bg-yellow-600 px-3 py-1.5 text-xs font-bold
                           text-white transition hover:bg-yellow-700">
                Verificar
            </button>
        </div>
    }
}

@code {
    [Parameter] public EventCallback OnUserUpdated { get; set; }

    private UserGQL? _user;
    private string _editName = "";
    private bool _savingName;
    private string? _nameMsg;
    private bool _nameError;
    private bool _avatarSuccess;
    private string? _avatarError;
    private bool _showEmailVerification;
    private bool _emailVerificationStep2;
    private bool _emailVerificationLoading;
    private string? _emailVerificationCode;
    private string? _emailVerificationError;

    private string AvatarSrc => _user?.AvatarUrl is null or "default.png"
        ? "/Avatars/default.png" : _user.AvatarUrl;

    protected override async Task OnInitializedAsync()
    {
        var result = await AuthService.GetCurrentUserAsync();
        if (result.IsSuccess)
        {
            _user = result.Value;
            UserState.User = _user;
        }
        _editName = _user?.Name ?? "";
    }

    private async Task SaveNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_editName) || _user is null) return;
        _savingName = true; _nameMsg = null;
        StateHasChanged();
        var result = await AuthService.UpdateProfileAsync(_editName.Trim(), null);
        if (result.IsSuccess)
        {
            _user.Name = _editName.Trim();
            UserState.User = _user;
            _nameMsg = "Nombre actualizado."; _nameError = false;
            await OnUserUpdated.InvokeAsync();
        }
        else { _nameMsg = "No se pudo guardar el nombre."; _nameError = true; }
        _savingName = false;
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _avatarError = null; _avatarSuccess = false;
        var file = e.File;
        if (file.Size > 5 * 1024 * 1024) { _avatarError = "La imagen no puede superar 5 MB."; return; }
        try
        {
            var bufferSize = file.Size > 50 * 1024 * 1024 ? 2 * 1024 * 1024 :
                             file.Size > 10 * 1024 * 1024 ? 1 * 1024 * 1024 : 524288;
            using var content = new MultipartFormDataContent();
            using var memoryStream = new MemoryStream();
            await using var readStream = file.OpenReadStream(file.Size);
            Memory<byte> buffer = new byte[bufferSize];
            int readBytes; long uploadedBytes = 0;
            while ((readBytes = await readStream.ReadAsync(buffer)) > 0)
            {
                memoryStream.Write(buffer.Span[..readBytes]);
                uploadedBytes += readBytes;
                StateHasChanged();
            }
            if (uploadedBytes != file.Size) { _avatarError = "Lectura incompleta del archivo."; return; }
            memoryStream.Position = 0;
            content.Add(new StreamContent(memoryStream), "file", file.Name);
            var response = await Http.PostAsync("/api/avatar", content);
            if (!response.IsSuccessStatusCode) { _avatarError = $"Error al subir (HTTP {response.StatusCode})"; return; }
            var json = await response.Content.ReadFromJsonAsync<AvatarResponse>();
            if (json?.Url is null) { _avatarError = "Respuesta del servidor inválida."; return; }
            var updateResult = await AuthService.UpdateProfileAsync(_user!.Name, json.Url);
            if (updateResult.IsSuccess)
            {
                _user!.AvatarUrl = json.Url;
                UserState.User = _user;
                _avatarSuccess = true;
                await OnUserUpdated.InvokeAsync();
            }
            else { _avatarError = "Foto subida pero no se pudo guardar."; }
        }
        catch (Exception ex) { _avatarError = $"Error: {ex.Message}"; }
    }

    private async Task ReloadUserAsync()
    {
        var result = await AuthService.GetCurrentUserAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _user = result.Value;
            UserState.User = _user;
            await OnUserUpdated.InvokeAsync();
            StateHasChanged();
        }
    }

    private async Task SendEmailVerificationCode()
    {
        _emailVerificationLoading = true; _emailVerificationError = null;
        StateHasChanged();
        try
        {
            var result = await GraphQL.ExecuteAsync<bool>("mutation { sendEmailVerificationCode }", null, "sendEmailVerificationCode");
            if (result) { _emailVerificationStep2 = true; _emailVerificationCode = ""; }
            else { _emailVerificationError = "No se pudo enviar el código"; }
        }
        catch (Exception ex) { _emailVerificationError = $"Error: {ex.Message}"; }
        finally { _emailVerificationLoading = false; StateHasChanged(); }
    }

    private async Task VerifyEmailCode()
    {
        if (string.IsNullOrEmpty(_emailVerificationCode) || _emailVerificationCode.Length != 6) return;
        _emailVerificationLoading = true; _emailVerificationError = null;
        StateHasChanged();
        try
        {
            var result = await GraphQL.ExecuteAsync<bool>(
                "mutation VerifyEmailCode($code: String!) { verifyEmailCode(code: $code) }",
                new { code = _emailVerificationCode }, "verifyEmailCode");
            if (result)
            {
                var userResult = await AuthService.GetCurrentUserAsync();
                if (userResult.IsSuccess && userResult.Value is not null)
                {
                    _user = userResult.Value;
                    UserState.User = _user;
                    await OnUserUpdated.InvokeAsync();
                }
                CloseEmailVerification();
            }
            else { _emailVerificationError = "Código inválido. Intenta de nuevo."; }
        }
        catch (Exception ex) { _emailVerificationError = $"Error: {ex.Message}"; }
        finally { _emailVerificationLoading = false; StateHasChanged(); }
    }

    private void CloseEmailVerification()
    {
        _showEmailVerification = false; _emailVerificationStep2 = false;
        _emailVerificationCode = null; _emailVerificationError = null;
        StateHasChanged();
    }

    private record AvatarResponse(string Url);
}
