@page "/account"
@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.Services.GraphQLServices
@using PiedraAzul.Client.States
@using PiedraAzul.Client.UI.Features.Account.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav
@inject UserState UserState
@inject AuthenticationService AuthService
@inject PasskeyService PasskeyService
@inject GraphQLHttpClient GraphQL
@inject HttpClient Http

<PageTitle>Mi cuenta | Piedra Azul</PageTitle>

<div class="mx-auto max-w-2xl px-4 py-10 space-y-6">

    @if (_loading)
    {
        <div class="flex justify-center py-20"><div class="spinner"></div></div>
    }
    else if (_user is null)
    {
        <p class="text-center text-gray-500">No se pudo cargar el perfil.</p>
    }
    else
    {
        <!-- Email Verification Banner -->
        @if (!string.IsNullOrEmpty(_user.Email) && !_user.EmailConfirmed)
        {
            <div class="rounded-lg border border-yellow-300 bg-yellow-50 p-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">📧</span>
                    <div>
                        <p class="font-semibold text-gray-800">Email no verificado</p>
                        <p class="text-sm text-gray-600">Verifica tu email para completar tu cuenta</p>
                    </div>
                </div>
                <button @onclick="() => _showEmailVerification = true"
                        class="rounded-lg bg-yellow-600 px-4 py-2 text-sm font-semibold text-white
                               transition hover:bg-yellow-700">
                    Verificar ahora
                </button>
            </div>
        }

        <!-- Profile card -->
        <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-xl">
            <h2 class="mb-5 text-xl font-bold text-gray-800">Mi perfil</h2>

            <!-- Avatar -->
            <div class="mb-6 flex items-center gap-5">
                <div class="relative">
                    <img src="@(_user.AvatarUrl == "default.png" ? "/Avatars/default.png" : _user.AvatarUrl)"
                         alt="Avatar"
                         class="h-20 w-20 rounded-full object-cover border-2 border-gray-200 shadow" />
                    <label class="absolute -bottom-1 -right-1 cursor-pointer rounded-full bg-[#257D8D]
                                  p-1.5 text-white shadow hover:bg-[#1E5F6F] transition"
                           title="Cambiar foto">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"
                                  stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                        </svg>
                        <InputFile OnChange="OnAvatarSelected" accept="image/*" class="hidden" />
                    </label>
                </div>
                <div>
                    <p class="font-semibold text-gray-800 text-lg">@_user.Name</p>
                    <p class="text-sm text-gray-500">@_user.Email</p>
                    <div class="mt-1 flex gap-1 flex-wrap">
                        @foreach (var role in _user.Roles)
                        {
                            <span class="rounded-full bg-teal-50 px-2 py-0.5 text-xs font-medium text-teal-700 capitalize">
                                @role
                            </span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_avatarError))
            {
                <p class="mb-3 text-sm text-red-500">@_avatarError</p>
            }
            @if (_avatarSuccess)
            {
                <p class="mb-3 text-sm text-green-600">Foto actualizada.</p>
            }

            <!-- Nombre -->
            <div class="mb-4">
                <label class="mb-1 block text-sm font-semibold text-gray-700">Nombre</label>
                <div class="flex gap-2">
                    <input @bind="_editName" @bind:event="oninput"
                           class="flex-1 rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700
                                  focus:border-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-400" />
                    <button @onclick="SaveNameAsync"
                            disabled="@(_savingName || _editName == _user.Name)"
                            class="rounded-lg bg-[#257D8D] px-4 py-2 text-sm font-semibold text-white
                                   transition hover:bg-[#1E5F6F] disabled:opacity-50">
                        @(_savingName ? "Guardando…" : "Guardar")
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_nameMsg))
                {
                    <p class="mt-1 text-xs @(_nameError ? "text-red-500" : "text-green-600")">@_nameMsg</p>
                }
            </div>

            @* Email change *@
            <div class="mb-5">
                <label class="mb-2 block text-sm font-semibold text-gray-700">Correo electrónico</label>
                <EmailChange CurrentEmail="@(_user.Email ?? "")" GraphQL="@GraphQL" OnEmailChanged="ReloadUserAsync" />
            </div>

            <!-- Logout -->
            <button @onclick="LogoutAsync"
                    class="w-full rounded-lg border border-red-200 py-2.5 text-sm font-semibold text-red-600
                           transition hover:bg-red-50">
                Cerrar sesión
            </button>
        </div>

        <!-- Security card -->
        <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-xl">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-xl font-bold text-gray-800">Seguridad</h2>
                <button @onclick='() => Nav.NavigateTo("/account/passkeys")'
                        class="rounded-lg bg-[#257D8D] px-4 py-2 text-sm font-semibold text-white
                               transition hover:bg-[#1E5F6F]">
                    + Registrar passkey
                </button>
            </div>

            <p class="mb-4 text-sm text-gray-500">
                Las passkeys te permiten ingresar con Face ID, huella dactilar o llave de seguridad USB — sin contraseña.
            </p>

            @if (_loadingPasskeys)
            {
                <div class="flex justify-center py-6"><div class="spinner"></div></div>
            }
            else if (_passkeys.Count == 0)
            {
                <div class="rounded-lg border border-dashed border-gray-200 py-8 text-center text-sm text-gray-400">
                    No tienes passkeys registradas aún.
                </div>
            }
            else
            {
                <ul class="space-y-2">
                    @foreach (var pk in _passkeys)
                    {
                        <li class="flex items-center justify-between rounded-lg border border-gray-100 bg-gray-50 px-4 py-3">
                            <div class="flex items-center gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600 flex-shrink-0"
                                     viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 1a5 5 0 1 0 0 10A5 5 0 0 0 12 1zm0 12c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z" />
                                </svg>
                                <div>
                                    <p class="text-sm font-semibold text-gray-700">@pk.FriendlyName</p>
                                    <p class="text-xs text-gray-400">@pk.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                                </div>
                            </div>
                            <button @onclick="() => DeletePasskeyAsync(pk.Id)"
                                    disabled="@_deletingPasskey"
                                    class="rounded-md px-3 py-1 text-xs font-medium text-red-500 border border-red-200
                                           hover:bg-red-50 transition disabled:opacity-50">
                                Eliminar
                            </button>
                        </li>
                    }
                </ul>
            }

            @* MFA Settings *@
            <div class="mt-6 pt-6 border-t border-gray-200">
                <MFASettings GraphQL="@GraphQL" CurrentEmail="@(_user?.Email ?? "")" />
            </div>
        </div>

        <!-- Email Verification Modal -->
        @if (_showEmailVerification)
        {
            <div class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
                <div class="rounded-lg bg-white p-6 shadow-lg max-w-sm w-full">
                    @if (!_emailVerificationStep2)
                    {
                        <!-- Step 1: Send Code -->
                        <h3 class="mb-3 text-lg font-bold text-gray-800">Verificar email</h3>
                        <p class="mb-5 text-sm text-gray-600">
                            Enviaremos un código de verificación a <strong>@_user.Email</strong>
                        </p>
                        <div class="flex gap-2">
                            <button @onclick="SendEmailVerificationCode"
                                    disabled="@_emailVerificationLoading"
                                    class="flex-1 rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white
                                           transition hover:bg-blue-700 disabled:opacity-50">
                                @(_emailVerificationLoading ? "Enviando..." : "Enviar código")
                            </button>
                            <button @onclick="() => _showEmailVerification = false"
                                    class="flex-1 rounded-lg border border-gray-300 px-4 py-2 font-semibold text-gray-700
                                           transition hover:bg-gray-50">
                                Cancelar
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_emailVerificationError))
                        {
                            <p class="mt-3 text-sm text-red-500">@_emailVerificationError</p>
                        }
                    }
                    else
                    {
                        <!-- Step 2: Verify Code -->
                        <h3 class="mb-3 text-lg font-bold text-gray-800">Ingresar código</h3>
                        <p class="mb-4 text-sm text-gray-600">
                            Ingresa el código de 6 dígitos que recibiste en tu email
                        </p>
                        <input type="text"
                               @bind="_emailVerificationCode"
                               maxlength="6"
                               placeholder="000000"
                               class="w-full mb-4 rounded-lg border border-gray-300 px-4 py-2 text-center text-2xl tracking-widest
                                      focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400"
                               autocomplete="off" />
                        <div class="flex gap-2 mb-3">
                            <button @onclick="VerifyEmailCode"
                                    disabled="@(_emailVerificationCode?.Length != 6 || _emailVerificationLoading)"
                                    class="flex-1 rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white
                                           transition hover:bg-blue-700 disabled:opacity-50">
                                @(_emailVerificationLoading ? "Verificando..." : "Verificar")
                            </button>
                            <button @onclick="CloseEmailVerification"
                                    class="flex-1 rounded-lg border border-gray-300 px-4 py-2 font-semibold text-gray-700
                                           transition hover:bg-gray-50">
                                Cancelar
                            </button>
                        </div>
                        <div class="space-y-2">
                            <button @onclick="() => _emailVerificationStep2 = false"
                                    class="w-full text-sm font-semibold text-blue-600 hover:text-blue-700">
                                ← Cambiar email
                            </button>
                            <button @onclick="CloseEmailVerification"
                                    class="w-full text-sm font-semibold text-gray-600 hover:text-gray-700">
                                Continuar sin verificar
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_emailVerificationError))
                        {
                            <p class="mt-3 text-sm text-red-500">@_emailVerificationError</p>
                        }
                    }
                </div>
            </div>
        }
    }

</div>

@code {
    private UserGQL? _user;
    private bool _loading = true;
    private bool _loadingPasskeys = true;

    private string _editName = "";
    private bool _savingName;
    private string? _nameMsg;
    private bool _nameError;

    private bool _avatarSuccess;
    private string? _avatarError;

    private List<PasskeyGQL> _passkeys = [];
    private bool _deletingPasskey;

    // Email verification
    private bool _showEmailVerification;
    private bool _emailVerificationStep2;
    private bool _emailVerificationLoading;
    private string? _emailVerificationCode;
    private string? _emailVerificationError;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.User is not null)
        {
            _user = UserState.User;
            _editName = _user.Name;
            _loading = false;
        }
        else
        {
            var result = await AuthService.GetCurrentUserAsync();
            if (result.IsSuccess)
            {
                _user = result.Value;
                UserState.User = _user;
                _editName = _user!.Name;
            }
            _loading = false;
        }

        await LoadPasskeysAsync();
    }

    private async Task LoadPasskeysAsync()
    {
        _loadingPasskeys = true;
        var result = await PasskeyService.GetMyPasskeysAsync();
        _passkeys = result.IsSuccess ? result.Value! : [];
        _loadingPasskeys = false;
    }

    private async Task SaveNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_editName) || _user is null) return;

        _savingName = true;
        _nameMsg = null;
        StateHasChanged();

        var result = await AuthService.UpdateProfileAsync(_editName.Trim(), null);

        if (result.IsSuccess)
        {
            _user.Name = _editName.Trim();
            UserState.User = _user;
            _nameMsg = "Nombre actualizado.";
            _nameError = false;
        }
        else
        {
            _nameMsg = "No se pudo guardar el nombre.";
            _nameError = true;
        }

        _savingName = false;
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _avatarError = null;
        _avatarSuccess = false;

        var file = e.File;
        const long maxSize = 5 * 1024 * 1024; // 5 MB
        if (file.Size > maxSize)
        {
            _avatarError = "La imagen no puede superar 5 MB.";
            return;
        }

        try
        {
            // Dynamic buffer size based on file size (como en PostHive)
            var bufferSize = file.Size > 50 * 1024 * 1024 ? 2 * 1024 * 1024 :
                             file.Size > 10 * 1024 * 1024 ? 1 * 1024 * 1024 :
                             524288; // Default 512 KB

            using var content = new MultipartFormDataContent();
            using var memoryStream = new MemoryStream();

            // Open stream - use file.Size since we already validated it
            await using var readStream = file.OpenReadStream(file.Size);

            // Manual read loop with dynamic buffer
            Memory<byte> buffer = new byte[bufferSize];
            int readBytes = 0;
            long totalBytes = file.Size;
            long uploadedBytes = 0;

            while ((readBytes = await readStream.ReadAsync(buffer)) > 0)
            {
                memoryStream.Write(buffer.Span[..readBytes]);
                uploadedBytes += readBytes;
                StateHasChanged(); // Mantener componente actualizado en cada chunk
            }

            if (uploadedBytes != totalBytes)
            {
                _avatarError = $"Lectura incompleta: {uploadedBytes} de {totalBytes} bytes";
                return;
            }

            memoryStream.Position = 0;
            content.Add(new StreamContent(memoryStream), "file", file.Name);

            var response = await Http.PostAsync("/api/avatar", content);
            if (!response.IsSuccessStatusCode)
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _avatarError = $"Error al subir (HTTP {response.StatusCode}): {errorContent}";
                return;
            }

            var json = await response.Content.ReadFromJsonAsync<AvatarResponse>();
            if (json?.Url is null)
            {
                _avatarError = "Respuesta del servidor inválida.";
                return;
            }

            var updateResult = await AuthService.UpdateProfileAsync(_user!.Name, json.Url);
            if (updateResult.IsSuccess)
            {
                _user!.AvatarUrl = json.Url;
                UserState.User = _user;
                _avatarSuccess = true;
            }
            else
            {
                _avatarError = "Foto subida pero no se pudo guardar en la base de datos.";
            }
        }
        catch (Exception ex)
        {
            _avatarError = $"Error: {ex.Message}";
        }
    }

    private async Task DeletePasskeyAsync(string id)
    {
        _deletingPasskey = true;
        var result = await PasskeyService.DeletePasskeyAsync(id);
        if (result.IsSuccess)
            _passkeys.RemoveAll(p => p.Id == id);
        _deletingPasskey = false;
    }

    private async Task LogoutAsync()
        => await AuthService.Logout();

    private async Task ReloadUserAsync()
    {
        var result = await AuthService.GetCurrentUserAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _user = result.Value;
            UserState.User = _user;
            StateHasChanged();
        }
    }

    private async Task SendEmailVerificationCode()
    {
        _emailVerificationLoading = true;
        _emailVerificationError = null;
        StateHasChanged();

        try
        {
            const string mutation = """
                mutation {
                    sendEmailVerificationCode
                }
                """;

            var result = await GraphQL.ExecuteAsync<bool>(
                mutation,
                null,
                "sendEmailVerificationCode");

            if (result)
            {
                _emailVerificationStep2 = true;
                _emailVerificationCode = "";
            }
            else
            {
                _emailVerificationError = "No se pudo enviar el código";
            }
        }
        catch (Exception ex)
        {
            _emailVerificationError = $"Error: {ex.Message}";
        }
        finally
        {
            _emailVerificationLoading = false;
            StateHasChanged();
        }
    }

    private async Task VerifyEmailCode()
    {
        if (string.IsNullOrEmpty(_emailVerificationCode) || _emailVerificationCode.Length != 6)
            return;

        _emailVerificationLoading = true;
        _emailVerificationError = null;
        StateHasChanged();

        try
        {
            const string mutation = """
                mutation VerifyEmailCode($code: String!) {
                    verifyEmailCode(code: $code)
                }
                """;

            var result = await GraphQL.ExecuteAsync<bool>(
                mutation,
                new { code = _emailVerificationCode },
                "verifyEmailCode");

            if (result)
            {
                // Recargar usuario desde la API para sincronizar EmailConfirmed
                var userResult = await AuthService.GetCurrentUserAsync();
                if (userResult.IsSuccess && userResult.Value is not null)
                {
                    _user = userResult.Value;
                    UserState.User = _user;
                }
                CloseEmailVerification();
            }
            else
            {
                _emailVerificationError = "Código inválido. Intenta de nuevo.";
            }
        }
        catch (Exception ex)
        {
            _emailVerificationError = $"Error: {ex.Message}";
        }
        finally
        {
            _emailVerificationLoading = false;
            StateHasChanged();
        }
    }

    private void CloseEmailVerification()
    {
        _showEmailVerification = false;
        _emailVerificationStep2 = false;
        _emailVerificationCode = null;
        _emailVerificationError = null;
        StateHasChanged();
    }

    private record AvatarResponse(string Url);
}
