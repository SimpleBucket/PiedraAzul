@page "/account"
@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.Services.GraphQLServices
@using PiedraAzul.Client.Services
@using PiedraAzul.Client.States
@using PiedraAzul.Client.UI.Features.Account.Sections
@using PiedraAzul.Client.UI.Features.Doctor
@using PiedraAzul.Client.UI.Features.Admin
@using PiedraAzul.Client.UI.Features.Appointments
@using PiedraAzul.Client.UI.Features.Booking.Pages
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav
@inject UserState UserState
@inject AuthenticationService AuthService
@inject GraphQLHttpClient GraphQL
@inject OfflineCacheService OfflineCache

<PageTitle>Mi cuenta | Piedra Azul</PageTitle>

@if (_loading)
{
    <div class="flex h-screen items-center justify-center" style="background:#F8FAFC">
        <div class="spinner"></div>
    </div>
}
else
{
    <div style="background:#F8FAFC;font-family:'DM Sans',sans-serif">

        <!-- Breadcrumb (desktop) -->
        <div class="hidden md:flex items-center gap-1.5 px-6 py-2 border-b border-[#E2E8F0] bg-white text-[13px] text-[#94A3B8] font-medium">
            <span>@_breadcrumbGroup</span>
            <span>›</span>
            <span class="text-[#0F172A] font-bold">@_breadcrumbItem</span>
        </div>

        <div class="flex" style="min-height:calc(100vh - 120px)">

            <!-- ══════════ SIDEBAR ══════════ -->
            <aside class="hidden md:flex w-60 bg-white border-r border-[#E2E8F0] flex-col flex-shrink-0 overflow-y-auto">

                <!-- User card -->
                <div class="px-4 py-5 border-b border-[#F1F5F9] text-center flex-shrink-0">
                    <div class="relative mx-auto mb-3 h-14 w-14">
                        <img src="@AvatarSrc" alt="Avatar"
                             class="h-14 w-14 rounded-full object-cover border-2 border-[#E2E8F0]" />
                        <div class="absolute bottom-0.5 right-0.5 h-3.5 w-3.5 rounded-full bg-[#10B981] border-2 border-white"></div>
                    </div>
                    <p class="text-[13px] font-bold text-[#0F172A] leading-snug">@_user?.Name</p>
                    <p class="mt-0.5 text-[11px] text-[#94A3B8] break-all">@_user?.Email</p>
                    <div class="mt-2 flex justify-center flex-wrap gap-1">
                        @foreach (var role in (_user?.Roles ?? []))
                        {
                            <span class="rounded-full bg-blue-50 px-2.5 py-0.5 text-[11px] font-bold text-blue-600 capitalize">@role</span>
                        }
                    </div>
                </div>

                <!-- Nav -->
                <nav class="flex-1 py-2 overflow-y-auto">

                    <!-- ── Mi Cuenta ── -->
                    @NavGroupHeader("Mi Cuenta", "mi-cuenta",
                        """<circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>""")
                    @if (IsGroupOpen("mi-cuenta"))
                    {
                        @NavItem("perfil", "Mi perfil", "Mi Cuenta")
                        @NavItem("seguridad", "Seguridad", "Mi Cuenta")
                        @NavItem("autenticacion", "Autenticación 2FA", "Mi Cuenta")
                    }
                    <div class="h-2"></div>

                    <!-- ── Portal Doctor ── -->
                    @if (IsDoctor)
                    {
                        @NavGroupHeader("Portal Doctor", "portal-doctor",
                            """<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>""")
                        @if (IsGroupOpen("portal-doctor"))
                        {
                            @NavItem("doc-dashboard", "Dashboard", "Portal Doctor")
                            @NavItem("doc-pacientes", "Pacientes", "Portal Doctor")
                            @NavItem("doc-agenda", "Mi Agenda", "Portal Doctor")
                            @NavItem("doc-cronograma", "Cronograma diario", "Portal Doctor")
                            @NavItem("doc-horario", "Mi Horario", "Portal Doctor")
                        }
                        <div class="h-2"></div>
                    }

                    <!-- ── Administración ── -->
                    @if (IsAdmin)
                    {
                        @NavGroupHeader("Administración", "administracion",
                            """<path d="M12 3l8 3.5v5c0 4.5-3.5 8.5-8 10-4.5-1.5-8-5.5-8-10v-5L12 3z"/>""")
                        @if (IsGroupOpen("administracion"))
                        {
                            @NavItem("admin-usuarios", "Gestión de usuarios", "Administración")
                            @NavItem("admin-agenda", "Agenda médica", "Administración")
                            @NavItem("admin-horario", "Configurar horarios", "Administración")
                        }
                        <div class="h-2"></div>
                    }

                    <!-- ── Servicios ── -->
                    @if (IsDoctor || IsAdmin)
                    {
                        @NavGroupHeader("Servicios", "servicios",
                            """<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>""")
                        @if (IsGroupOpen("servicios"))
                        {
                            @NavItem("exportar-citas", "Exportar citas (XLS)", "Servicios")
                            @NavItem("agendar-manual", "Agendar manualmente", "Servicios")
                        }
                        <div class="h-2"></div>
                    }

                </nav>

                <!-- Logout -->
                <div class="px-3 pb-3 pt-2 border-t border-[#F1F5F9] flex-shrink-0">
                    <button @onclick="LogoutAsync"
                            class="flex w-full items-center gap-2.5 rounded-xl border border-[#FEE2E2] bg-white px-3.5 py-2.5
                                   text-[13px] font-bold text-[#E11D48] transition hover:bg-red-50">
                        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7"/><path d="M9 20H6a2 2 0 01-2-2V6a2 2 0 012-2h3"/>
                        </svg>
                        Cerrar sesión
                    </button>
                </div>
            </aside>

            <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
            <main class="flex-1 p-4 md:p-7 overflow-y-auto">
                @switch (_tab)
                {
                    case "perfil":
                        <ProfileSection OnUserUpdated="OnUserUpdated" />
                        break;
                    case "seguridad":
                        <SecuritySection />
                        break;
                    case "autenticacion":
                        <TwoFASection />
                        break;
                    case "doc-dashboard":
                        <DoctorPanel />
                        break;
                    case "doc-pacientes":
                        <DoctorPatients />
                        break;
                    case "doc-agenda":
                        <DoctorAgenda />
                        break;
                    case "doc-cronograma":
                        <DoctorDailySchedule />
                        break;
                    case "doc-horario":
                        <DoctorScheduleConfig />
                        break;
                    case "admin-usuarios":
                        <UserManagement />
                        break;
                    case "admin-agenda":
                        <AdminAgenda />
                        break;
                    case "admin-horario":
                        <AdminScheduleConfig />
                        break;
                    case "exportar-citas":
                        <AppointmentExport />
                        break;
                    case "agendar-manual":
                        <ManualBooking />
                        break;
                    default:
                        <ProfileSection OnUserUpdated="OnUserUpdated" />
                        break;
                }
            </main>
        </div>
    </div>
}

@code {
    private UserGQL? _user;
    private bool _loading = true;
    private string _tab = "perfil";
    private Dictionary<string, bool> _collapsed = new();

    private string AvatarSrc => _user?.AvatarUrl is null or "default.png"
        ? "/Avatars/default.png" : _user.AvatarUrl;

    private bool IsDoctor => _user?.Roles.Contains("Doctor") == true;
    private bool IsAdmin  => _user?.Roles.Contains("Admin") == true;

    private string _breadcrumbGroup = "Mi Cuenta";
    private string _breadcrumbItem  = "Mi perfil";

    protected override async Task OnInitializedAsync()
    {
        if (UserState.User is not null)
        {
            _user = UserState.User;
            _loading = false;
        }
        else
        {
            var result = await AuthService.GetCurrentUserAsync();
            if (result.IsSuccess) { _user = result.Value; UserState.User = _user; }
            _loading = false;
        }
    }

    private void Navigate(string tab, string group, string item)
    {
        _tab = tab; _breadcrumbGroup = group; _breadcrumbItem = item;
        StateHasChanged();
    }

    private void ToggleGroup(string key) =>
        _collapsed[key] = !(_collapsed.TryGetValue(key, out var v) && v);

    private bool IsGroupOpen(string key) =>
        !(_collapsed.TryGetValue(key, out var v) && v);

    private void OnUserUpdated() { _user = UserState.User; StateHasChanged(); }

    private async Task LogoutAsync()
    {
        await OfflineCache.ClearAsync();
        await AuthService.Logout();
    }

    private RenderFragment NavGroupHeader(string name, string key, string pathsInner) => __builder =>
    {
        var open = IsGroupOpen(key);
        var capturedKey = key;
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "class", "flex w-full items-center justify-between px-4 pt-2 pb-1.5 bg-transparent border-0 cursor-pointer");
        __builder.AddAttribute(2, "onclick", EventCallback.Factory.Create(this, () => ToggleGroup(capturedKey)));
        __builder.AddMarkupContent(3, $"""
            <div class="flex items-center gap-1.5">
                <svg class="h-3.5 w-3.5 text-[#94A3B8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">{pathsInner}</svg>
                <span class="text-[10px] font-extrabold uppercase tracking-[0.1em] text-[#94A3B8]">{name}</span>
            </div>
            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                 style="transform:{(open ? "rotate(0deg)" : "rotate(-90deg)")};transition:transform .2s">
                <path d="m6 9 6 6 6-6"/>
            </svg>
        """);
        __builder.CloseElement();
    };

    private RenderFragment NavItem(string tab, string label, string group) => __builder =>
    {
        var active = _tab == tab;
        var capturedTab = tab; var capturedGroup = group; var capturedLabel = label;
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "class",
            $"flex w-full items-center gap-2.5 px-4 py-2.5 text-[14px] font-medium transition border-l-[3px] " +
            (active ? "border-[#257D8D] bg-[#e8f4f6] text-[#257D8D] font-bold"
                    : "border-transparent text-[#374151] hover:bg-gray-50"));
        __builder.AddAttribute(2, "onclick",
            EventCallback.Factory.Create(this, () => Navigate(capturedTab, capturedGroup, capturedLabel)));
        __builder.OpenElement(3, "span");
        __builder.AddAttribute(4, "class",
            $"h-1.5 w-1.5 rounded-full flex-shrink-0 " + (active ? "bg-[#257D8D]" : "bg-[#CBD5E1]"));
        __builder.CloseElement();
        __builder.AddContent(5, label);
        __builder.CloseElement();
    };
}
