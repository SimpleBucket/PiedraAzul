@page "/admin/agenda"
@using global::Shared.Grpc
@inject PiedraAzul.Client.Services.GrpcServices.GrpcAppointmentService AppointmentService
@inject PiedraAzul.Client.Services.GrpcServices.GrpcDoctorService DoctorService

<div class="min-h-screen bg-slate-50 p-8">
    <div class="max-w-7xl mx-auto">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-slate-900">Agenda Médica</h1>
                <p class="text-slate-500 mt-1">Gestión y listado de citas de los especialistas</p>
            </div>
            
            <a href="/booking/manual" class="bg-teal-800 hover:bg-teal-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Agendar Manualmente
            </a>
        </div>

        <!-- Filtros -->
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Especialista</label>
                <select class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" @bind="SelectedDoctorId">
                    <option value="">Selecciona un médico...</option>
                    @foreach (var doc in doctores)
                    {
                        <option value="@doc.UserId">@doc.Name (@doc.Specialty)</option>
                    }
                </select>
            </div>
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Fecha</label>
                <input type="date" class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" value="@SelectedDate.ToString("yyyy-MM-dd")" @onchange="OnDateChange" />
            </div>

            <div class="flex items-end">
                <button class="w-full bg-slate-800 hover:bg-slate-900 text-white px-4 py-2.5 rounded-lg font-medium transition-colors shadow-sm" @onclick="CargarCitas">
                    Filtrar Agenda
                </button>
            </div>
        </div>

        <!-- Tabla de Citas -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Hora</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Paciente</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Motivo/Servicio</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (citas == null || !citas.Any())
                        {
                            <tr><td colspan="5" class="text-center py-6 text-slate-500">No hay citas para mostrar en esta fecha o seleccione un médico.</td></tr>
                        }
                        else
                        {
                            @foreach (var cita in citas)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                     <td class="py-4 px-6">
                                         <div class="font-semibold text-slate-800">
                                             @cita.CreatedAt.ToDateTime().ToLocalTime().ToString("hh:mm tt")
                                         </div>
                                     </td>
                                     <td class="py-4 px-6">
                                         <div class="font-medium text-slate-900">@cita.PatientName</div>
                                         <div class="text-sm text-slate-500">Tipo: @cita.PatientType</div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <div class="inline-flex px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-medium">Consulta Médica</div>
                                    </td>
                                    <td class="py-4 px-6">
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-medium border border-amber-200/50">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                            Confirmada
                                        </span>
                                    </td>
                                    <td class="py-4 px-6 text-right">
                                        <button class="text-teal-600 hover:text-teal-800 font-medium text-sm transition-colors mr-3">Ver Detalle</button>
                                        <button class="text-rose-500 hover:text-rose-700 font-medium text-sm transition-colors">Cancelar</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Paginación -->
            <div class="p-4 border-t border-slate-100 flex items-center justify-between text-sm text-slate-500">
                <div>Mostrando resultados del médico</div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<DoctorResponse> doctores = new();
    private List<AppointmentResponse> citas = new();
    private string SelectedDoctorId { get; set; } = "";
    private DateTime SelectedDate { get; set; } = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        // Traeremos los especialistas iterando sobre el enum (0, 1, 2, 3)
        // Ya que el método nativo retorna por grupo.
        for (int i = 0; i <= 3; i++)
        {
            var result = await DoctorService.GetDoctorsByTypeAsync((global::PiedraAzul.Shared.Enums.DoctorType)i);
            if (result != null && result.Any())
            {
                doctores.AddRange(result);
            }
        }
    }

    private void OnDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
        }
    }

    private async Task CargarCitas()
    {
        if (string.IsNullOrEmpty(SelectedDoctorId)) return;
        
        var request = new DoctorAppointmentsRequest 
        { 
            DoctorId = SelectedDoctorId, 
            Date = Google.Protobuf.WellKnownTypes.Timestamp.FromDateTime(SelectedDate.ToUniversalTime()) 
        };
        
        var result = await AppointmentService.GetDoctorAppointments(request);
        if (result.IsSuccess && result.Value != null)
        {
            citas = result.Value.Appointments.ToList();
        }
    }
}
