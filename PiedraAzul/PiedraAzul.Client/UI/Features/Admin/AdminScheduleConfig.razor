@page "/admin/configurar-horario"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using System.Globalization
@using PiedraAzul.Client.States
@inject UserState UserState

<div class="min-h-screen bg-slate-50 pb-12">

   <!-- HEADER / NAV -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="bg-primary p-2 rounded-lg text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                </div>
                <span class="text-xl font-bold text-slate-800">Agendador <span class="text-xs text-primary font-medium opacity-60">Admin</span></span>
            </div>

            <div class="flex items-center gap-6">
                <button class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                </button>
                <div class="flex items-center gap-3 pl-6 border-l">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=257D8D&color=fff" alt="Admin" class="w-8 h-8 rounded-full border shadow-sm" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 mt-8">
        <!-- Specialist Search Header -->
        <div class="flex flex-col md:flex-row items-end justify-between gap-6 mb-12">
            <div>
                <h1 class="text-5xl font-black text-slate-900 mb-2">Configurar Horario</h1>
                <p class="text-slate-500 text-lg font-medium">Gestiona tu disponibilidad semanal para citas con pacientes.</p>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Especialista</label>
                <div class="bg-white p-2 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-4 min-w-[400px]">
                    <div class="pl-4 text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <input type="text" placeholder="Selecciona un especialista" class="flex-1 bg-transparent border-none focus:outline-none text-slate-700 font-bold" />
                    <button class="bg-primary text-white px-8 py-3 rounded-xl font-bold hover:opacity-90 transition-all shadow-lg shadow-primary/20">
                        BUSCAR
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

