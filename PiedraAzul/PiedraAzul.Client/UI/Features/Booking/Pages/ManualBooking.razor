@page "/booking/manual"
@using Google.Protobuf.WellKnownTypes
@using PiedraAzul.Client.Models.Booking
@using PiedraAzul.Client.Models.UserProfiles
@using PiedraAzul.Client.Services.GrpcServices
@using PiedraAzul.Client.Services.Utils
@using PiedraAzul.Client.UI.Features.Booking.Components
@using PiedraAzul.Client.UI.Shared.Components
@using global::Shared.Grpc

@inject GrpcPatientService PatientService
@inject GrpcAppointmentService AppointmentService

<EditForm Model="@Model" OnValidSubmit="HandlerSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mx-auto min-h-screen max-w-5xl space-y-10 bg-gray-100 p-8">

        <!-- HEADER -->
        <div class="space-y-1">
            <h1 class="text-3xl font-bold text-gray-900">Agendamiento Manual</h1>
            <p class="text-sm text-gray-500">
                Registro de nueva cita médica
            </p>
        </div>

        <!-- PACIENTE -->
        <div class="space-y-6 rounded-2xl bg-white p-6 shadow-md">

            <h2 class="text-lg font-semibold text-gray-800">
                Datos del Paciente
            </h2>

            <!-- BUSCADOR -->
            <div>
                <label class="text-xs font-semibold uppercase text-gray-500">
                    Buscar paciente
                </label>

                <div class="mt-2 flex gap-3">
                    <InputText @oninput="HandlerInputSearch" @bind-Value="Search"
                               class="w-full rounded-xl border px-4 py-3"
                               placeholder="Ej: 10203040 o Juan Perez" />

                    <button type="button" @onclick="HandlerSearch"
                            class="rounded-xl bg-teal-600 px-6 py-3 text-white">
                        Buscar
                    </button>
                </div>
            </div>

            <!-- RESULTADOS -->
            <div class="grid gap-4 md:grid-cols-2">

                @if (SearchResult.Any())
                {
                    @foreach (var patient in SearchResult)
                    {
                        var isSelected = SelectedPatient?.Id == patient.Id;

                        <div class="@GetPatientClass(isSelected)"
                             @onclick="() => SelectPatient(patient)">

                            <p class="text-xs font-semibold uppercase">
                                Paciente encontrado
                            </p>

                            <p class="mt-1 text-base font-bold">
                                @patient.PatientName
                            </p>

                            <p class="text-xs">
                                CC: @patient.PatientIdentification • @patient.PatientPhone
                            </p>

                            <p class="font-bold text-[10px] text-gray-400">
                                @(patient.IsRegistered ? "Registrado" : "Invitado")
                            </p>

                        </div>
                    }
                }
                else
                {
                    <div class="p-4 text-sm text-gray-400">
                        No hay resultados
                    </div>
                }

                <!-- NUEVO PACIENTE -->
                @if (!_isNewPatient)
                {
                    <div @onclick="() => _isNewPatient = true"
                         class="cursor-pointer border-2 border-dashed p-4 text-center">
                        + Registrar nuevo paciente
                    </div>
                }
                else
                {
                    <div class="col-span-2 space-y-4 border p-4">

                        <InputText @bind-Value="Model.PatientIdentification" placeholder="Cédula" />
                        <InputText @bind-Value="Model.PatientName" placeholder="Nombre" />
                        <InputText @bind-Value="Model.PatientPhone" placeholder="Teléfono" />

                    </div>
                }

            </div>
        </div>

        <!-- DOCTOR -->
        <div class="rounded-2xl bg-white p-6 shadow-md">

            <MenuTypeMedic OnSelected="HandlerSelectDoctor" OnChange="HandlerChange" />

            @if (Model.Doctor != null)
            {
                <AppointmentScheduler DoctorId="@Model.DoctorId"
                                      OnSelected="HandlerSelectAppointmentDate" />
            }

        </div>

        <!-- ACCIONES -->
        <button type="submit" class="w-full bg-teal-600 py-3 text-white">
            Guardar
        </button>

    </div>

</EditForm>

@code {

    private BookingModel Model { get; set; } = new();
    private List<PatientModel> SearchResult { get; set; } = new();
    private string? Search { get; set; }
    private bool _isNewPatient = false;

    private PatientModel? SelectedPatient;
    private CancellationTokenSource? _cts;

    private async Task HandlerSearch()
    {
        var response = await PatientService.SearchPatientsAsync(Search, 10);

        SearchResult = response.Select(p => new PatientModel
        {
            Id = p.Id,
            PatientName = p.Name,
            PatientIdentification = p.Identification,
            PatientPhone = p.Phone,
            Type = p.Type
        }).ToList();
    }

    private async Task HandlerInputSearch(ChangeEventArgs args)
    {
        if (args.Value == null) return;

        var query = args.Value.ToString();

        _cts?.Cancel();
        _cts = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, _cts.Token);

            if (string.IsNullOrWhiteSpace(query) || query.Length < 3)
            {
                SearchResult = new();
                return;
            }

            var response = await PatientService.SearchAutoCompletePatientsAsync(query, 10);

            SearchResult = response.Select(p => new PatientModel
            {
                Id = p.Id,
                PatientName = p.Name,
                PatientIdentification = p.Identification,
                PatientPhone = p.Phone,
                Type = p.Type
            }).ToList();
        }
        catch { }
    }

    private void SelectPatient(PatientModel patient)
    {
        SelectedPatient = patient;

        Model.PatientName = patient.PatientName;
        Model.PatientIdentification = patient.PatientIdentification;
        Model.PatientPhone = patient.PatientPhone;
    }

    private string GetPatientClass(bool isSelected)
    {
        return isSelected
            ? "border-2 border-teal-500 p-4"
            : "border p-4 cursor-pointer";
    }

    private void HandlerSelectDoctor(DoctorModel args)
    {
        Model.DoctorId = args.Id;
        Model.Doctor = args;
    }

    private async Task HandlerChange()
    {
        Model = new();
        SelectedPatient = null;
        await InvokeAsync(StateHasChanged);
    }

    private void HandlerSelectAppointmentDate(AppointmentSchedulerModel args)
    {
        Model.SlotId = args.SlotId;
        Model.DayOfYear = args.Date;
    }

    private async Task HandlerSubmit()
    {
        var request = new CreateAppointmentRequest
        {
            DoctorId = Model.DoctorId,
            DoctorAvailabilitySlotId = Model.SlotId,
            Date = Timestamp.FromDateTime(Model.DayOfYear.ToUniversalTime())
        };

        if (SelectedPatient != null)
        {
            if (SelectedPatient.IsRegistered)
            {
                request.PatientUserId = SelectedPatient.Id;
            }
            else
            {
                request.Guest = CreateContracts.CreateGuestPatientInput(SelectedPatient.PatientName, SelectedPatient.PatientPhone, SelectedPatient.PatientIdentification, "");
            }
        }
        else
        {
            request.Guest = CreateContracts.CreateGuestPatientInput(SelectedPatient.PatientName, SelectedPatient.PatientPhone, SelectedPatient.PatientIdentification, "");
        }

        var result = await AppointmentService.CreateAppointment(request);

        if (!result.IsSuccess)
        {
            Console.WriteLine(result.Error.Message);
        }
    }
}