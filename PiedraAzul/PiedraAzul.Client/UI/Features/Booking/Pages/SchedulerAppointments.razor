@page "/scheduler/appointments"
@using global::Shared.Grpc
@inject PiedraAzul.Client.Services.GrpcServices.GrpcDoctorService DoctorService
@inject PiedraAzul.Client.Services.GrpcServices.GrpcAppointmentService AppointmentService

<div class="mx-auto max-w-7xl space-y-6 px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-900">Listado de citas por médico/terapista</h1>

    <div class="grid grid-cols-1 gap-4 rounded-xl bg-white p-4 shadow md:grid-cols-4">
        <div class="md:col-span-2">
            <label class="mb-1 block text-sm font-semibold text-gray-700">Médico/Terapista</label>
            <select class="w-full rounded-lg border px-3 py-2" @bind="selectedDoctorUserId">
                <option value="">Seleccione un médico</option>
                @foreach (var doctor in doctors)
                {
                    <option value="@doctor.UserId">@doctor.Name - @doctor.Specialty</option>
                }
            </select>
        </div>

        <div>
            <label class="mb-1 block text-sm font-semibold text-gray-700">Fecha (Colombia)</label>
            <input class="w-full rounded-lg border px-3 py-2" type="date" @bind-value="selectedDate" @bind-value:format="yyyy-MM-dd" />
        </div>

        <div class="flex items-end">
            <button class="w-full rounded-lg bg-teal-700 px-4 py-2 font-semibold text-white hover:bg-teal-800"
                    @onclick="SearchAsync"
                    disabled="@isLoading">
                @(isLoading ? "Buscando..." : "Buscar")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">@message</div>
    }

    <div class="rounded-xl bg-white p-4 shadow">
        <div class="mb-3 flex items-center justify-between">
            <p class="text-sm text-gray-600">Se encontraron <span class="font-bold">@totalCount</span> citas.</p>
            <p class="text-sm text-gray-600">Página @pageNumber de @totalPages</p>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full border-collapse border border-gray-200 text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="border border-gray-200 px-3 py-2 text-left">Hora</th>
                        <th class="border border-gray-200 px-3 py-2 text-left">Paciente</th>
                        <th class="border border-gray-200 px-3 py-2 text-left">Tipo paciente</th>
                        <th class="border border-gray-200 px-3 py-2 text-left">Especialidad</th>
                        <th class="border border-gray-200 px-3 py-2 text-left">Estado</th>
                        <th class="border border-gray-200 px-3 py-2 text-left">Fecha creación</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items.Count == 0)
                    {
                        <tr>
                            <td class="border border-gray-200 px-3 py-5 text-center text-gray-500" colspan="6">Sin resultados</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in items)
                        {
                            <tr>
                                <td class="border border-gray-200 px-3 py-2">@item.TimeRange</td>
                                <td class="border border-gray-200 px-3 py-2">@item.Patient</td>
                                <td class="border border-gray-200 px-3 py-2">@item.PatientType</td>
                                <td class="border border-gray-200 px-3 py-2">@item.Specialty</td>
                                <td class="border border-gray-200 px-3 py-2">@item.Status</td>
                                <td class="border border-gray-200 px-3 py-2">@item.CreatedAt.ToDateTime().ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 flex justify-end gap-2">
            <button class="rounded border px-3 py-1 disabled:opacity-50" @onclick="PrevPageAsync" disabled="@(pageNumber <= 1 || isLoading)">Anterior</button>
            <button class="rounded border px-3 py-1 disabled:opacity-50" @onclick="NextPageAsync" disabled="@(pageNumber >= totalPages || isLoading)">Siguiente</button>
        </div>
    </div>
</div>

@code {
    private readonly int pageSize = 50;
    private bool isLoading;
    private string selectedDoctorUserId = string.Empty;
    private DateTime selectedDate = DateTime.Today;
    private string message = string.Empty;

    private List<DoctorResponse> doctors = [];
    private List<DoctorAppointmentItem> items = [];

    private int totalCount;
    private int pageNumber = 1;
    private int totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        doctors = await DoctorService.GetDoctorsAsync();
    }

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAppointmentsAsync();
    }

    private async Task PrevPageAsync()
    {
        if (pageNumber <= 1)
            return;

        pageNumber--;
        await LoadAppointmentsAsync();
    }

    private async Task NextPageAsync()
    {
        if (pageNumber >= totalPages)
            return;

        pageNumber++;
        await LoadAppointmentsAsync();
    }

    private async Task LoadAppointmentsAsync()
    {
        message = string.Empty;
        items.Clear();

        if (string.IsNullOrWhiteSpace(selectedDoctorUserId))
        {
            message = "Debe seleccionar un médico o terapista.";
            totalCount = 0;
            totalPages = 1;
            return;
        }

        isLoading = true;

        var result = await AppointmentService.GetDoctorAppointments(selectedDoctorUserId, selectedDate, pageNumber, pageSize);

        if (!result.IsSuccess || result.Value == null)
        {
            message = string.IsNullOrWhiteSpace(result.Error?.Message)
                ? "No fue posible consultar las citas médicas."
                : result.Error!.Message;
            totalCount = 0;
            totalPages = 1;
            isLoading = false;
            return;
        }

        items = result.Value.Items.ToList();
        totalCount = result.Value.TotalCount;
        totalPages = Math.Max(1, (int)Math.Ceiling(totalCount / (double)pageSize));

        if (totalCount == 0)
        {
            message = "No se encontraron citas para el médico y la fecha seleccionados.";
        }

        isLoading = false;
    }
}