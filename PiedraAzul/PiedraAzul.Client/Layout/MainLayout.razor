@inherits LayoutComponentBase


<div class="min-h-screen flex flex-col bg-gray-50">

    <!-- TOP BAR -->
    <div class="bg-primary text-white text-sm">
        <div class="max-w-7xl mx-auto flex justify-between px-6 py-2">
            <span>Llámanos: (301) 123-4567</span>
            <span>WhatsApp: Escríbenos ahora</span>
        </div>
    </div>

    <!-- HEADER -->
    <header class="bg-white border-b">
        <div class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">

            <a href="/" class="flex items-center gap-2 text-teal-700 font-semibold text-lg">
                <span class="text-xl"></span>
                Piedra Azul
            </a>

            <nav class="flex items-center gap-8 text-gray-600">
                <a class="hover:text-gray-900">Servicios</a>
                <a class="hover:text-gray-900">Ayuda</a>

                <button class="bg-primary text-white px-4 py-2 rounded-md hover:bg-teal-800">
                    Iniciar Sesión
                </button>
            </nav>

        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>

    <!-- FOOTER -->
    <footer class="bg-strong text-gray-300">
        <div class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-10">

            <div>
                <h3 class="text-white font-semibold text-lg mb-4 flex items-center gap-2">
                    Piedra Azul
                </h3>

                <p class="text-sm text-gray-400">
                    Dedicados a mejorar la calidad de vida de nuestra comunidad
                    con atención profesional y humana.
                </p>
            </div>

            <div>
                <h4 class="text-white font-semibold mb-4">Enlaces</h4>

                <ul class="space-y-2 text-sm">
                    <li><a class="hover:text-white">Acerca de nosotros</a></li>
                    <li><a class="hover:text-white">Servicios médicos</a></li>
                    <li><a class="hover:text-white">Preguntas frecuentes</a></li>
                    <li><a class="hover:text-white">Política de privacidad</a></li>
                </ul>
            </div>

            <div>
                <h4 class="text-white font-semibold mb-4">Contacto Directo</h4>

                <div class="space-y-3">

                    <button class="w-full bg-teal-600 hover:bg-teal-700 text-white py-2 rounded-md">
                        (+57) 301-1234567
                    </button>

                    <button class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-md">
                        WhatsApp
                    </button>

                </div>
            </div>

        </div>

        <div class="border-t border-slate-700 text-center text-sm text-gray-500 py-4">
            © 2026 Clínica Piedra Azul. Todos los derechos reservados.
        </div>

    </footer>

</div>




<div id="blazor-error-ui"
     data-nosnippet
     class="fixed bottom-0 left-1/2 -translate-x-1/2 bg-white border border-red-200 shadow-xl rounded-xl p-6 max-w-lg w-[90%]">

    <div class="flex items-start gap-4">
        <div class="flex-1">

            <h2 class="text-lg font-semibold text-gray-800 mb-1">
                Algo no salió como esperábamos
            </h2>

            <p class="text-gray-600 text-sm mb-4">
                No se preocupe, esto a veces ocurre.
                Puede intentar recargar la página para continuar.
            </p>

            <div class="flex gap-3">

                <a href="."
                       class="reload bg-[#3A7D8C] hover:bg-[#2f6773] text-white px-4 py-2 rounded-lg text-sm font-medium shadow">
                    Recargar página
                </a>
            </div>

        </div>
    </div>
</div>