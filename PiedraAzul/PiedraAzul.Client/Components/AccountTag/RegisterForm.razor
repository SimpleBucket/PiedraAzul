<div class="flex flex-col items-center">
    <div class="w-full max-w-lg">
        <h2 class="mb-2 text-left text-3xl font-bold">Crea tu cuenta</h2>
        <p class="text-left">Por favor llena tus datos debajo del recuadro para iniciar.</p>
        <p class="text-left">Escriba en las cajas de texto</p>
        <!--Login form-->
        <form action="" class="mt-5 p-3 shadow">
            <div class="flex flex-col">
                <label for="" class="font-semibold">Su nombre completo:</label>
                <input class="rounded-md border border-[#257D8D] px-3 py-4 outline-none focus:ring-2 focus:ring-teal-400" type="text" autocomplete="name" name="login" id="" placeholder="Ej: 10 123 4567" />
            </div>
            <div class="flex flex-col">
                <label for="" class="font-semibold">Correo electrónico:</label>
                <input class="rounded-md border border-[#257D8D] px-3 py-4 outline-none focus:ring-2 focus:ring-teal-400" type="email" autocomplete="email" name="login" id="" placeholder="Ej: ejemplo@gmail.com" />
            </div>
            <div class="flex flex-col">
                <label for="" class="font-semibold"> Cree su contraseña </label>
                <input type="password" autocomplete="off" class="rounded-md border border-[#257D8D] px-3 py-4 outline-none focus:ring-2 focus:ring-teal-400" name="login" id="" placeholder="Ej: tu contraseña super secreta" />
            </div>
            <div class="flex flex-col">
                <label for="" class="font-semibold"> Repita su contraseña </label>
                <input type="password" autocomplete="off" class="rounded-md border border-[#257D8D] px-3 py-4 outline-none focus:ring-2 focus:ring-teal-400" name="login" id="" placeholder="Ej: tu contraseña super secreta de nuevo" />
            </div>
            <p class="mt-2 text-sm text-gray-500">Tip: Use una combinación de letras y números para mantenerse más seguro.</p>

            <div class="mt-3 grid gap-3 md:grid-cols-2">
                <button @onclick="async () => await OnLoginClick.InvokeAsync()" type="submit" class="cursor-pointer rounded-md border border-[#CBD5E1] bg-[#E2E8F0] p-3 text-balance transition-colors duration-200 hover:bg-[#CBD5E1]">¿Tienes una cuenta, presiona aqui para ingresar?</button>

                <button type="submit" class="cursor-pointer text-balance rounded-md border border-[#CBD5E1] bg-[#257D8D] p-3 transition-colors duration-200 hover:bg-[#1E5F6F]">Presiona para registrarte</button>
            </div>
        </form>
    </div>
</div>
@code {
    [Parameter]
    public EventCallback OnLoginClick { get; set; }
}